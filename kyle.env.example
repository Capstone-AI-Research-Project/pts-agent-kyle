# =============================================================================
#  pts-agent-kyle — environment configuration template
# -----------------------------------------------------------------------------
#  Copy this file to .env and adjust values for your deployment:
#      cp .env.example .env
#
#  Required values (no safe default) are marked REQUIRED below.
#  All other values fall back to the defaults shown if left unset.
# =============================================================================


# -----------------------------------------------------------------------------
#  n8n — workflow orchestrator
# -----------------------------------------------------------------------------
# REQUIRED: basic-auth credentials for the n8n web UI at $N8N_HOSTNAME:$N8N_PORT.
# Pick anything you can remember; these are local-only and never leave the host.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASS=change-me-please

# REQUIRED: token used for n8n internal task-runner authentication.
# Generate with:    openssl rand -hex 32
N8N_AUTH_TOKEN=replace-with-a-32+-character-random-token

# Public hostname / protocol / port (defaults work for local development).
N8N_PROTOCOL=http
N8N_HOSTNAME=localhost
N8N_PORT=5678

# Per-execution timeout in seconds. Bump higher (e.g. 7200) on slower hardware
# where the qwen2.5:14b agents take longer to respond.
EXECUTIONS_TIMEOUT=2400


# -----------------------------------------------------------------------------
#  PostgreSQL — n8n database
# -----------------------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=n8n


# -----------------------------------------------------------------------------
#  Redis — n8n queue
# -----------------------------------------------------------------------------
# Leave password empty for a quick local stand-up; set one for any shared host.
REDIS_PASSWORD=
REDIS_DB=0


# -----------------------------------------------------------------------------
#  Ollama — local LLM inference
# -----------------------------------------------------------------------------
# Port on the host that Ollama's API listens on.
LLAMA_PORT=11434

# How long an idle model stays warm in memory. Higher = fewer cold-start delays
# but more sustained RAM usage.
OLLAMA_KEEP_ALIVE=30m

# Maximum number of models held in RAM simultaneously.
# 64GB host: leave at 4 (all 6 CASA agents fit comfortably).
# 16GB host: drop to 1 — Ollama will swap models on demand (slower but safe).
OLLAMA_MAX_LOADED_MODELS=4

# Concurrent requests Ollama will service in parallel.
OLLAMA_NUM_PARALLEL=2

# CPU threads per model. Set to (physical cores) on CPU-only deployments;
# leave at 16 on 16+ vCPU AWS instances.
OLLAMA_NUM_THREAD=16


# -----------------------------------------------------------------------------
#  Open WebUI — analyst chat interface
# -----------------------------------------------------------------------------
OWUI_PORT=3000


# -----------------------------------------------------------------------------
#  System
# -----------------------------------------------------------------------------
# IANA timezone name. Used by n8n for cron expressions and report timestamps.
GENERIC_TIMEZONE=America/Phoenix
